{
  "name": "@assistant-ui/react-ink",
  "version": "0.0.4",
  "description": "React Ink (terminal UI) bindings for assistant-ui",
  "keywords": [
    "assistant",
    "ai",
    "chat",
    "ink",
    "terminal",
    "cli"
  ],
  "author": "AgentbaseAI Inc.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "aui-source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./internal": {
      "aui-source": "./src/internal.ts",
      "types": "./dist/internal.d.ts",
      "default": "./dist/internal.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "aui-build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@assistant-ui/core": "^0.1.5",
    "@assistant-ui/store": "^0.2.2",
    "@assistant-ui/tap": "^0.5.2",
    "assistant-stream": "^0.3.5",
    "ink-spinner": "^5.0.0",
    "zustand": "^5.0.11"
  },
  "peerDependencies": {
    "@types/react": "*",
    "ink": ">=4",
    "react": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@assistant-ui/x-buildutils": "workspace:*",
    "@types/react": "^19.2.14",
    "ink": "^5.2.0",
    "ink-testing-library": "^4.0.0",
    "react": "18.3.1",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "homepage": "https://www.assistant-ui.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/assistant-ui/assistant-ui.git",
    "directory": "packages/react-ink"
  },
  "bugs": {
    "url": "https://github.com/assistant-ui/assistant-ui/issues"
  }
}
