{
  "name": "@assistant-ui/monorepo",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "cleanup": "bash scripts/cleanup-monorepo.sh",
    "docs:dev": "pnpm --filter=@assistant-ui/docs dev",
    "ci:version": "changeset version && pnpm install --no-frozen-lockfile",
    "ci:publish": "turbo build --filter=\"./packages/*\" && changeset publish",
    "build": "turbo build",
    "lint": "pnpm exec biome check",
    "lint:fix": "pnpm exec biome check --fix",
    "test": "turbo test",
    "prepare": "husky",
    "deps:check": "npx taze major -f -r",
    "deps:update": "npx taze major -f -w -r && cd examples/with-expo && npx expo install --fix && cd ../.. && pnpm install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@changesets/cli": "^2.30.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.30.3",
  "lint-staged": {
    "*": "biome check --fix --no-errors-on-unmatched"
  },
  "browserslist": [
    "chrome 111",
    "edge 111",
    "firefox 111",
    "safari 16.4"
  ]
}
