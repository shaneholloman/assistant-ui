{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": ["ENABLE_EXPERIMENTAL_COREPACK"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "**/*.*",
        "!.next",
        "!.turbo",
        "!dist",
        "!build",
        "!generated",
        "!.output",
        "!.source"
      ],
      "outputs": [
        "dist",
        ".next/**",
        "!.next/cache/**",
        "generated/**",
        ".output/**",
        "build/**"
      ],
      "env": [
        "OPENAI_*",
        "ASSISTANT_*",
        "JWT_*",
        "ENTELLIGENCE_*",
        "NEXT_PUBLIC_*",
        "KV_*",
        "SENTRY_*",
        "REDIS_*",
        "AI_GATEWAY_*",
        "AUIX_*"
      ]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "deploy": {
      "dependsOn": ["build", "lint", "test"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
